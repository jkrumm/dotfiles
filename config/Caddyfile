# free-planning-poker — web (Next.js), server (Bun WS), analytics (FastAPI),
# logdy UI. Ports 7723-7726 reserved; 7724-7726 are logdy ingest sockets and
# don't need .test hosts. Caddy auto-handles WebSocket upgrades for fpp-server.
#
# fpp.test rewrites Host → localhost:7720 because Next.js dev server checks
# the Host header on dev-only endpoints (/__nextjs_original-stack-frames,
# _next/webpack-hmr); a foreign host returns 403 / drops the WS upgrade.
fpp.test {
	import local
	reverse_proxy localhost:7720 {
		header_up Host localhost:7720
	}
}
fpp-server.test {
	import local
	reverse_proxy localhost:7721
}
fpp-analytics.test {
	import local
	reverse_proxy localhost:7722
}
fpp-logdy.test {
	import local
	reverse_proxy localhost:7723
}

# LocalAI stack runs on each Mac as 127.0.0.1:8000 (mlx-audio).
# Hermes connects to localhost:8000 directly. Other clients (Hermes Python
# SDK, scripts) work fine with mlx-audio's NDJSON Content-Type.
#
# MacWhisper exception: its custom-OpenAI provider chokes on
# Content-Type `application/x-ndjson` (raises "Daten fehlen") even though
# the body is a single JSON object. The block below proxies STT through
# Caddy and rewrites Content-Type → `application/json` so MacWhisper
# accepts it. Point MacWhisper Base URL at https://whisper.test and use
# any Parakeet model (e.g. mlx-community/parakeet-tdt-0.6b-v3).
whisper.test {
	import local
	# /v1/audio/transcriptions → localai-helper :8001 (transforms response
	# from Parakeet's {text, sentences} to OpenAI verbose_json
	# {text, segments, language, duration} so MacWhisper can parse it).
	# Everything else → mlx-audio :8000 directly.
	handle /v1/audio/transcriptions* {
		reverse_proxy localhost:8001 {
			transport http {
				versions 1.1
			}
			flush_interval -1
		}
	}
	handle /v1/* {
		reverse_proxy localhost:8000
	}
}

# ─── VPN-only AWS web UIs (via prometheus-scripts/vpn sidecar) ───────────────
# Caddy fronts the public hostname on 127.0.0.1:443; the sidecar binds a
# non-443 port and forwards over the AWS Client VPN tunnel. /etc/hosts pin
# (managed by `make vpn-web-install` in ~/IuRoot/prometheus-scripts/vpn)
# routes the hostname to 127.0.0.1 so Caddy gets the request first.
# Browser sees Caddy's local-CA cert; Caddy verifies the real upstream cert.

metabase.iu-aws.de {
	tls internal
	reverse_proxy https://127.0.0.1:24443 {
		header_up Host metabase.iu-aws.de
		transport http {
			tls
			tls_server_name metabase.iu-aws.de
		}
	}
}
