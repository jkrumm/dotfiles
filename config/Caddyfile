# Local development reverse proxy — version-controlled in dotfiles
#
# Adding a service:
#   name.test {
#     import local
#     reverse_proxy localhost:PORT
#   }
#
# Reload config: caddy reload   (no sudo needed)
#
# Stack:
#   dnsmasq  — wildcard *.test → 127.0.0.1 (no per-domain DNS config ever)
#   Caddy    — reverse proxy + HTTPS via local CA (tls internal)
#
# One-time setup: make setup  (sudo required for dnsmasq + Caddy services only)

(local) {
	tls internal
}

# Redirect all HTTP *.test traffic to HTTPS
http://*.test {
	redir https://{host}{uri} 301
}

