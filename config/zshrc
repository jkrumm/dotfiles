# OPENSPEC:START
# OpenSpec shell completions — must run before any compdef calls
fpath=("$HOME/.zsh/completions" $fpath)
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi
# OPENSPEC:END

# ── Navigation ────────────────────────────────────────────────────────────────
# j <dir>            jump to best match (zoxide)
# ji                 interactive jump with fzf
# Ctrl+T             fuzzy file picker — insert path at cursor
# Ctrl+R             fuzzy history search
# Alt+C              fuzzy cd into subdirectory
#
# ── Line editing ─────────────────────────────────────────────────────────────
# Option+Left/Right  jump word        (requires macos-option-as-alt = left)
# Ctrl+A / Ctrl+E    line start / end
# Ctrl+W             delete word before cursor
# Ctrl+U             clear line
# Ctrl+K             delete to end of line
#
# ── Claude Code ──────────────────────────────────────────────────────────────
# c [args]           launch Claude Code — auto-detects workspace, loads skills
#                    SourceRoot → ~/SourceRoot/.claude skills
#                    IuRoot    → per-project .claude/ skills
#
# ── AI shell helpers ─────────────────────────────────────────────────────────
# ai "<desc>"        generate zsh command from description → confirm → run
# fix                re-run last failed command, ask Claude to fix → confirm
#
# ── Git ──────────────────────────────────────────────────────────────────────
# nb <branch>        smart branch switch / create
#                    • switches + rebases if branch exists (local or remote)
#                    • creates from origin/default otherwise
#                    • offers to carry ahead commits to new branch
# gback              git reset --soft HEAD~1 (undo last commit, keep staged)
# wtp add <branch>   create worktree + run post_create hooks
# wtp cd <name>      navigate to worktree
# wtp list           list all worktrees
# wtp remove <name>  remove worktree  (--with-branch to also delete branch)
#
# ── SSH / Infra ──────────────────────────────────────────────────────────────
# homelab            ssh homelab
# vps                ssh vps
# rebuild-vps <c>    rebuild docker container on VPS  (e.g. rebuild-vps fpp-server)
#
# ── Apps ─────────────────────────────────────────────────────────────────────
# zed [dir]          open dir (or cwd) in Zed
# tailscale <cmd>    Tailscale CLI
#
# ── IU (work) ────────────────────────────────────────────────────────────────
# start-iu-fe        start all IU frontend dev servers
# sync-iu-db         sync IU dev database
# aws-login [env]    AWS SSO login for IDSS (Dev|Non-Prod|Prod|Shared, default Non-Prod)
#                    sets AWS_PROFILE to aws.CP.IDSS.<env>
#
# ── Misc ─────────────────────────────────────────────────────────────────────
# sz                 reload ~/.zshrc
#
# ── Modules (config/zsh/*.zsh → ~/.zsh/conf.d/) ──────────────────────────────
# path.zsh · secrets.zsh · tools.zsh · keybindings.zsh
# aliases.zsh · claude.zsh · git.zsh · ai.zsh

for f in ~/.zsh/conf.d/*.zsh(N); do source "$f"; done


# Vite+ bin (https://viteplus.dev)
. "$HOME/.vite-plus/env"

